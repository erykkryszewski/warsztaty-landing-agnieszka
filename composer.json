{
  "name": "ercoding/mini-cms-starter",
  "description": "A lightweight PHP starter CMS for brochure websites.",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/Helpers/helpers.php"
    ]
  },
  "scripts": {
    "post-autoload-dump": [
      "@php -r \"if (!is_dir('storage/logs')) { mkdir('storage/logs', 0777, true); }\""
    ]
  }
}
