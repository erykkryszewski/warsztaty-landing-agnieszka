<?php

declare(strict_types=1);

use App\Core\Env;
use App\Deployment\DeployPackageBuilder;

define('BASE_PATH', __DIR__);

require BASE_PATH . '/vendor/autoload.php';

Env::load(BASE_PATH . '/.env');

$builder = new DeployPackageBuilder(BASE_PATH);
